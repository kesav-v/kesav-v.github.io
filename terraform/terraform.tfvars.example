# Copy this file to terraform.tfvars and fill in your values
# terraform.tfvars is in .gitignore and won't be committed

aws_region     = "us-east-1"
instance_type  = "t2.micro"
key_pair_name  = "your-key-pair-name"

# Security: Restrict SSH access to your IP address
# Find your IP at https://whatismyipaddress.com/
# Format: "YOUR_IP_ADDRESS/32" (e.g., "203.0.113.42/32")
# Use "0.0.0.0/0" to allow from anywhere (NOT recommended for production)
allowed_ssh_cidr = "0.0.0.0/0"  # Change this to your IP/32

