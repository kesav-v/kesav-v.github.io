# Spotify app credentials for Clipify (https://developer.spotify.com/dashboard)
#
# REACT_APP_SPOTIFY_REDIRECT_URI is only used on local loopback dev (127.0.0.1 / localhost).
# Production builds use the current site origin automatically (https://kesav-v.github.io/).
#
# Local dev: save this redirect URI in your Spotify app, then run: npm run start:clipify
#   REACT_APP_SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
REACT_APP_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
REACT_APP_SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
